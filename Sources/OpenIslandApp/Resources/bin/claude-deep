#!/bin/zsh
# Claude Code routed through Open Island proxy, locked to the
# DeepSeek family. The active GUI profile must have an id starting
# with `deepseek-` (e.g. `deepseek-v4-pro`, `deepseek-v4-flash`,
# or a custom `deepseek-*` profile). If the active card is BuerAI /
# Anthropic / anything else, the proxy returns a 400 explaining the
# mismatch — `claude-deep` is intentionally narrower than `claude-3`.
#
# Usage:
#   claude-deep [args...]
#       Routes through the proxy. The proxy enforces that whatever
#       deepseek-* card is GUI-active is the one that handles the
#       request.
#   OI_PROFILE=<id> claude-deep [args...]
#       Per-invocation profile override; identical to `OI_PROFILE`
#       on `claude-3`. The override id can be any registered profile
#       (not just deepseek-*) — when set, it wins and the family
#       constraint does not apply.
#
# Environment:
#   OPEN_ISLAND_PORT  proxy port (default 9710)
#   OI_PROFILE        per-invocation profile override id. When set,
#                     same path as claude-3's override knob — the
#                     family lock is bypassed for that one call.
#                     Documented as an advanced escape hatch; most
#                     users should leave it unset and rely on the
#                     family enforcement.
#
# Pairs with:
#   claude         — official binary, OAuth direct connect (do not
#                    touch — Anthropic Max/Pro client identity check
#                    fails through any proxy).
#   claude-3       — proxy routing for any GUI-active profile, no
#                    family constraint.
#   claude-native  — explicitly bypass the proxy for ambient OAuth.

: "${OPEN_ISLAND_PORT:=9710}"

if [ -n "${OI_PROFILE:-}" ]; then
    base="http://127.0.0.1:${OPEN_ISLAND_PORT}/_oi/profile/${OI_PROFILE}"
else
    base="http://127.0.0.1:${OPEN_ISLAND_PORT}/_oi/family/deepseek"
fi

exec env ANTHROPIC_BASE_URL="${base}" claude "$@"
